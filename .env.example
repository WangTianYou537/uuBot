# ---- uuBot bootstrap configuration (copy to .env and edit) ----

# Database connection (SeaORM). Pick ONE:
#   SQLite (default, zero-setup):
DATABASE_URL=sqlite://data.db?mode=rwc
#   MySQL:    mysql://user:pass@localhost:3306/uubot
#   Postgres: postgres://user:pass@localhost:5432/uubot

# HTTP listen address
BIND_ADDR=0.0.0.0:8080

# Public base URL — used to build the OAuth redirect_uri. Must be reachable
# by the browser AND match what you configured at the login provider.
PUBLIC_BASE_URL=http://localhost:8080

# Secret used to sign session tokens. CHANGE THIS in production.
JWT_SECRET=change-me-in-production-please

# Seed admin account, created on first startup if no admin exists.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Set true when serving over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false
